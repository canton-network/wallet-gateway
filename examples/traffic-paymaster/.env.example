# Copy to `.env` in this directory (repo root `.gitignore` already ignores `.env`).

# From `daml build` output / DAR layout (`paymaster-traffic-1.0.0-<hash>/...`)
VITE_PACKAGE_ID=53b9285ee3e1c024eb1bc2f52574ab9081c78827e855baf57dee88e7ba64d3f2

VITE_PAYMASTER_PARTY=REPLACE_WITH_PAYMASTER_PARTY
VITE_PURCHASE_TRAFFIC_CID=REPLACE_WITH_CID
VITE_ELIGIBLE_RATE_CID=REPLACE_WITH_CID
VITE_DEMO_HOLDING_CID=REPLACE_WITH_CID

VITE_DEFAULT_TRAFFIC_ACCOUNT=traffic-purchase
VITE_CURRENCY_SYMBOL=DEMO
VITE_UNITS_PER_LU=1

# Optional: Wallet Gateway dApp API (JSON-RPC over HTTP; default path /api/v0/dapp)
# Same URL the ping e2e tests use for a local gateway (port 3030 is wallet-gateway-remote default).
VITE_WALLET_GATEWAY_URL=http://localhost:3030/api/v0/dapp
